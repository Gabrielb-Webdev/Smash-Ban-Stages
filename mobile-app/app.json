{
  "expo": {
    "name": "La app sin H",
    "slug": "afk-smash-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "backgroundColor": "#0a0a0a",
    "icon": "./assets/afk-favicon.png",
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.afksmash.mobile",
      "versionCode": 16,
      "permissions": ["INTERNET"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/afk-favicon.png",
        "monochromeImage": "./assets/afk-favicon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ]
  }
}

