{
  "expo": {
    "name": "AFK Smash",
    "slug": "afk-smash-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/afk-icon.png",
    "splash": { "backgroundColor": "#000000", "resizeMode": "contain" },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.afksmash.mobile",
      "permissions": ["INTERNET"],
      "adaptiveIcon": { "foregroundImage": "./assets/afk-icon.png", "backgroundColor": "#000000" }
    },
    "owner": "gabriel_sin_h",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "eas": { "projectId": "1cc82cc6-5c6c-437d-aa76-3a3d79eda94e" }
    }
  }
}
